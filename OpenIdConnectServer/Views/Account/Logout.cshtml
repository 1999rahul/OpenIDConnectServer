@{
    ViewData["Title"] = "Sign out";
}

<div class="row justify-content-center text-center">
    <div class="col-md-5">
        <h2>Sign out</h2>
        <p>Do you want to sign out?</p>
        <form asp-controller="Authorization" asp-action="LogoutPost" method="post">
            <button type="submit" class="btn btn-danger">Yes, sign me out</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>